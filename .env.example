# Expo public env vars (safe to expose to the client bundle)
# Create a local `.env` file (NOT committed) with real values.
#
# For EAS builds, set these via `eas secret:create` or your CI/CD.

EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# Optional: Brand Firebase Auth email action links (verification/reset)
# - LINK_DOMAIN must be a Firebase Hosting domain configured on your project (can be a custom domain)
# - CONTINUE_URL is where users land after completing the action
#
# Examples:
# EXPO_PUBLIC_AUTH_EMAIL_LINK_DOMAIN=www.876nurses.com
# EXPO_PUBLIC_AUTH_EMAIL_CONTINUE_URL=https://www.876nurses.com
#
# If your main website is hosted elsewhere, consider a dedicated subdomain on Firebase Hosting:
# EXPO_PUBLIC_AUTH_EMAIL_LINK_DOMAIN=auth.876nurses.com
# EXPO_PUBLIC_AUTH_EMAIL_CONTINUE_URL=https://www.876nurses.com

# Optional: if you want EmailService to call your backend
# EXPO_PUBLIC_BACKEND_URL=http://localhost:3000
